# Custos environment variables
# Copy to .env and fill in real values. Never commit .env.

# LLM provider: claude | openai | local
LLM_PROVIDER=claude

# Claude API key (required when LLM_PROVIDER=claude)
ANTHROPIC_API_KEY=sk-ant-PLACEHOLDER

# Claude model ID (override when a model is deprecated/renamed)
# CUSTOS_MODEL=claude-sonnet-4-6

# OpenAI API key (required when LLM_PROVIDER=openai)
# OPENAI_API_KEY=sk-PLACEHOLDER

# Embedder provider: local | openai
# Default is local (BGE-small). Documents never leave your infra with local.
EMBEDDER_PROVIDER=local

# Qdrant vector store
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=custos

# Corpus generation (deterministic)
CORPUS_SEED=42
CORPUS_REFERENCE_DATE=2026-07-17
